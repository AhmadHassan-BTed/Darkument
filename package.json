{
  "name": "darkument",
  "version": "1.0.4",
  "description": "Invert PDFs, Documents and Web-Pages for late-night study sessions.",
  "main": "src/background.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "powershell -Command \"New-Item -ItemType Directory -Force -Path build; Compress-Archive -Path src/* -DestinationPath build/Darkument-v$($env:npm_package_version).zip -Force\"",
    "clean": "rm -rf build/*.zip"
  },
  "keywords": [
    "darkmode",
    "pdf",
    "invert",
    "eyes-protection",
    "extension"
  ],
  "author": "Ahmad Hassan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ahmad-Hassan-0/Darkument.git"
  }
}
