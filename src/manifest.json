{
  "manifest_version": 3,
  "name": "Darkument",
  "version": "1.0.3",
  "description": "Invert PDFs, Documents and Web-Pages. Study late-nights wish me well :) by Ahmad Hassan.",
  "action": {
    "default_title": "Activate Darkument",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}