{
  "manifest_version": 3,
  "name": "Darkument",
  "version": "1.0.3",
  "description": "Invert PDFs, Documents and Web-Pages. Study late-nights wish me well :) by Ahmad Hassan.",
  "action": {
    "default_title": "Activate Darkument",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}